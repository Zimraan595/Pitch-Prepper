# Copy this file to `.env` (in this backend/ folder) and fill in real values.
# The real .env is gitignored, so your secrets are never committed.
#
#   cp .env.example .env      # then edit .env
#
# The app loads this automatically on startup (via python-dotenv), so it works
# no matter how you launch it — Git Bash, an IDE "Run" button, double-click, etc.

# --- MongoDB (user accounts + leaderboard) ---------------------------------
# Your real Atlas connection string. Copy it from Atlas → Connect → Drivers and
# replace <db_password> with your real password. No angle brackets should remain.
# Example shape (use YOUR cluster host / user / password):
MONGO_URI=mongodb+srv://myuser:mypassword@users.abcde.mongodb.net/?retryWrites=true&w=majority

# --- Login session signing key ---------------------------------------------
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# --- Optional overrides (safe to leave commented; these are the defaults) ---
# MONGO_DB_NAME=presentation_helper
# WHISPER_MODEL=base
# LLM_MODEL=llama3.1
# OLLAMA_HOST=http://localhost:11434
