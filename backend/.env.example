# Copy this file to `.env` (in this backend/ folder) and fill in real values.
# The real .env is gitignored, so your secrets are never committed.
#
#   cp .env.example .env      # then edit .env
#
# The app loads this automatically on startup (via python-dotenv), so it works
# no matter how you launch it — Git Bash, an IDE "Run" button, double-click, etc.

# --- MongoDB (user accounts + leaderboard) ---------------------------------
# Your real Atlas connection string. Copy it from Atlas → Connect → Drivers and
# replace <db_password> with your real password. No angle brackets should remain.
# Example shape (use YOUR cluster host / user / password):
MONGO_URI=mongodb+srv://myuser:mypassword@users.abcde.mongodb.net/?retryWrites=true&w=majority

# --- Login session signing key ---------------------------------------------
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# --- Gemini (AI content feedback) ------------------------------------------
# Content analysis uses Google's Gemini API. The free tier is plenty for this —
# create a key at https://aistudio.google.com/apikey and paste it here.
# NOTE: with a key set, your transcript text is sent to Google for analysis.
# Leave GEMINI_API_KEY blank to keep everything on-machine (a built-in heuristic
# fills in for the AI feedback).
# GEMINI_API_KEY=your-gemini-api-key

# --- "Hear how it could sound" playback (ElevenLabs, OPTIONAL) --------------
# This is the only feature that sends data off your machine (your transcript
# text goes to ElevenLabs), and it runs only when you click "Generate ideal
# delivery". Leave ELEVENLABS_API_KEY blank/unset to keep the feature hidden.
# ELEVENLABS_API_KEY=your-elevenlabs-api-key
# Voice that reads the script. Leave unset to auto-pick a voice you OWN.
# NOTE: the free tier can't use the shared library voices (Rachel, etc.) — you
# must create/clone your own voice in your ElevenLabs account.
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL=eleven_multilingual_v2
# ELEVENLABS_API_BASE=https://api.elevenlabs.io
# Gemini model that tightens the transcript before synthesis (not ElevenLabs).
# GEMINI_REWRITE_MODEL=gemini-2.5-flash
# Caps transcript chars sent for rewrite + synthesis (latency / credit control).
# IDEAL_DELIVERY_MAX_CHARS=5000

# --- Other optional overrides (safe to leave commented; these are defaults) -
# MONGO_DB_NAME=presentation_helper
# WHISPER_MODEL=base
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_API_BASE=https://generativelanguage.googleapis.com
# SESSION_DAYS=30
# MIN_RECORDING_SEC=15
